---
// 引入你的布局组件（名字可能叫 Layout 或 BaseLayout）
import Layout from '../layouts/Layout.astro'; 
import { getCollection } from 'astro:content';

const allReports = (await getCollection('reports')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="我的技术简报">
  <main>
    <h1>每日技术简报</h1>
    <ul>
      {allReports.map(post => (
        <li>
          <a href={`/astro_website/reports/${post.slug}/`}>
            {post.data.title}
          </a>
          <span>({post.data.pubDate.toLocaleDateString()})</span>
        </li>
      ))}
    </ul>
    
    {allReports.length === 0 && <p>📦 仓库还是空的，请检查 OpenClaw 搬运工是否干活了。</p>}
  </main>
</Layout>
