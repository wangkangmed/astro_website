---
import { getCollection } from 'astro:content';

const allReports = (await getCollection('reports')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <title>我的技术简报</title>
</head>
<body>
  <h1>🚀 每日技术简报</h1>
  <ul>
    {allReports.map(post => (
      <li>
        {/* 这里坚决使用 post.id，并且使用反引号 */}
        <a href={`/astro_website/reports/${post.id}/`}>{post.data.title}</a>
        <span style="color: #888; margin-left: 10px;">
          ({post.data.pubDate.toLocaleDateString()})
        </span>
      </li>
    ))}
  </ul>
</body>
</html>
